# 测试 suite 不在 .env 里持久化 API key——凭据来自系统环境变量。
#
# 在 AWS host(/home/ubuntu)上,这些已经配在 ~/.bash_profile 里,
# 用 `ssh -t my-aws bash -lc 'cd ... && npm run test'` 跑测试即可读到。
#
# 必须存在的系统 env(SDK 自己校验,缺一报错):
#   ANTHROPIC_AWS_API_KEY        AWS Console 发的 API key,SDK 走 x-api-key
#   ANTHROPIC_AWS_WORKSPACE_ID   wrkspc_*,workspace 标识
#   AWS_REGION                   e.g. ap-northeast-1
#
# 本 .env 仅放**测试套件自己的可选 flag**,不放凭据。

# 控制 Multi-agent / Memory / Outcomes 测试是否跑(需 research preview access)
# https://claude.com/form/claude-managed-agents
CMA_RESEARCH_PREVIEW=false

# 每次跑测试唯一 id,用于 cleanup 时筛选本次创建的资源。
# 不填则启动时自动生成 ULID。
CMA_TEST_RUN_ID=
