# --- CMA_MODE: direct | aws-platform ---
# direct: 本地开发,用 Anthropic Direct API
# aws-platform: AWS host 上跑,Claude Platform on AWS(注意不是经典 Bedrock)
CMA_MODE=direct

# --- Direct API(CMA_MODE=direct 时必填) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Claude Platform on AWS(CMA_MODE=aws-platform 时必填,二选一) ---
# 选项 a:AWS Console 生成的 API key
AWS_ANTHROPIC_BASE_URL=https://aws-external-anthropic.us-west-2.api.aws
AWS_ANTHROPIC_API_KEY=
# 选项 b:WIF token(从 token-generator-for-aws-external-anthropic-js 拿)
AWS_ANTHROPIC_WIF_TOKEN=

# --- 通用 ---
ANTHROPIC_BETA_HEADER=managed-agents-2026-04-01
CMA_TEST_REGION=us-west-2

# 控制 Multi-agent / Memory / Outcomes 测试是否跑(需 research preview access)
# https://claude.com/form/claude-managed-agents
CMA_RESEARCH_PREVIEW=false

# 每次跑测试唯一 id,用于 cleanup 时筛选本次创建的资源
# 不填则启动时自动生成
CMA_TEST_RUN_ID=
